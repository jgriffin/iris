# Xcode
## User-specific
xcuserdata/
Apps/**/xcuserdata/
Apps/**/*.xcworkspace/xcuserdata/
*.xcuserstate
*.xcuserstatev2
*.xcscmblueprint
*.xccheckout

## Build artifacts
DerivedData/
build/
*.o
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

## Per-developer signing — kept out of git via xcconfig override.
## Shared.xcconfig (committed) does `#include? "Local.xcconfig"`.
Apps/**/Local.xcconfig

## Other
*.moved-aside
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3

# Core ML compiled models (committed sources only)
*.mlmodelc/

# Model-export tooling outputs (tools/model-export/ — see its RUNBOOK.md).
# Tracked here: RUNBOOK.md, scripts, pyproject/lock. Ignored: the venv, plus
# any downloaded weights / converted .mlpackages that ultralytics drops in the
# CWD (the canonical home is data/models/ — these two lines are a safety net).
tools/model-export/.venv/
tools/model-export/*.pt
tools/model-export/*.mlpackage

# Model artifacts (data/models/ — regenerable; the README is tracked).
data/models/weights/
data/models/coreml/

# Icon generator outputs (tools/icongen/ — see Sources/). Tracked: the Swift
# generator (Package.swift, Sources/). Ignored: the regenerable preview renders
# (contact sheet + per-variant size ramps). The SHIPPED icon lives in the app's
# Apps/Shared/Assets.xcassets/ and IS tracked.
tools/icongen/preview/
tools/icongen/.build/

# Datasets and captured frames (project-specific outputs)
datasets/
captures/
*.mov
*.mp4
!**/fixtures/*.mov
!**/fixtures/*.mp4

# Environment / secrets
.env
.env.local
*.pem
*.p12

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Git worktrees (kept inside the repo, ignored so they never show as untracked
# in the main tree). Create with: git worktree add .worktrees/<name> <branch>
.worktrees/

# Claude / planning workspace artifacts
.planning/cache/
.claude/local/

# Claude Code worktrees
.claude/worktrees/
