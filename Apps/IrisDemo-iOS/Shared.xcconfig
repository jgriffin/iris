// Shared build settings for IrisDemo-iOS. Committed to git.
//
// Per-developer overrides (DEVELOPMENT_TEAM) come from Local.xcconfig,
// which is gitignored. Bootstrap a clone via:
//     cp Local.xcconfig.template Local.xcconfig
// then fill in your team ID. See Local.xcconfig.template for details.

// Device family is shared; PRODUCT_BUNDLE_IDENTIFIER lives in Local.xcconfig
// because the reverse-DNS prefix is tied to your developer account.
TARGETED_DEVICE_FAMILY = 1,2

// Info.plist
INFOPLIST_FILE = IrisDemo-iOS/Info.plist
GENERATE_INFOPLIST_FILE = NO

// Swift
SWIFT_VERSION = 6.0
SWIFT_STRICT_CONCURRENCY = complete

// Previews + sandboxing
ENABLE_PREVIEWS = YES
ENABLE_USER_SCRIPT_SANDBOXING = YES

// Code-signing style here; DEVELOPMENT_TEAM lives in Local.xcconfig.
CODE_SIGN_STYLE = Automatic

// Per-developer overrides. Local.xcconfig is gitignored.
// The `?` makes the include optional — project still opens cleanly if
// Local.xcconfig hasn't been created yet; signing just fails at build time
// with a clear "no team selected" error.
#include? "Local.xcconfig"
